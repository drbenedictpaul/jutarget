# --- Julia Specifics ---
# Compiled files (Generated by Julia to speed up loading)
*.ji

# Crash logs and symbols
*.dSYM/
*.mem

# Coverage files (Generated when running tests with coverage)
*.cov
*.coverage
lcov.info

# Documentation build folder
docs/build/
docs/site/

# Artifacts and build dependencies
deps/deps.jl
deps/build.log
deps/downloads/
deps/usr/

# --- VS Code Specifics ---
# Editor settings (ignore this to avoid overriding other people's settings)
.vscode/

# History and backups
*.history

# --- General ---
# Mac OS annoying file
.DS_Store

# User-specific environment variables (Security!)
.env

*.csv
*.tar.gz
*.tar


# --- Proprietary / Patent-Pending Files ---
