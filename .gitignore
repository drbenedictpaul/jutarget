src/jutarget_ml.jl

# Ignore the trained model and data, as they are part of the IP
reference/chem_resistance_model.jld2
reference/training_data.csv


# --- Standard Julia ignores ---
/Manifest.toml
*.log
*.so
*.dll
*.dylib
*.stacktrace

